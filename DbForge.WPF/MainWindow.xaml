<Window x:Class="DbForge.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:DbForge.WPF.Models"

        Title="DbForge Studio"
        Width="1280" Height="750"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- ── Menu bar ───────────────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Connection..." Click="NewConnection_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="_Schema Compare" Click="SchemaCompare_Click">
                </MenuItem>
            </MenuItem>

        </Menu>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main layout: left tree | splitter | right content ──────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="150" MaxWidth="500"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Object Explorer panel -->
            <DockPanel Grid.Column="0">

                <!-- Panel header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="0,0,0,1" Padding="8,5">
                    <TextBlock Text="Object Explorer" FontWeight="SemiBold" FontSize="12"/>
                </Border>

                <!-- Toolbar -->
                <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
                    <ToolBar Band="0" BandIndex="0">
                        <Button Content="Connect..." Click="NewConnection_Click" ToolTip="New Connection"/>
                    </ToolBar>
                </ToolBarTray>

                <!-- Tree — binds to MainViewModel.Servers -->
                <TreeView BorderThickness="0" ItemsSource="{Binding Servers}">
                    <TreeView.Resources>

                        <!-- Server node: shows its Databases collection as children -->
                        <HierarchicalDataTemplate DataType="{x:Type models:ServerNode}"
                                                  ItemsSource="{Binding Databases}">
                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                <TextBlock Text="⚡ " FontSize="12"/>
                                <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <!-- Database leaf (each item is just a string) -->
                        <DataTemplate DataType="{x:Type sys:String}">
                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                <TextBlock Text="🗄 " FontSize="12"/>
                                <TextBlock Text="{Binding}" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>

                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>

            <!-- Resize handle -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>

            <!-- Right content area — empty for now, tabs/editor goes here later -->
            <Grid Grid.Column="2">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           Text="Connect to a server to begin"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           FontSize="15"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>