<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:compareVm="clr-namespace:DbForge.WPF.ViewModels.Compare"
    xmlns:helpers="clr-namespace:DbForge.WPF.UI.Helpers">

    <DataTemplate x:Key="ConnectionSideTemplate"
                  DataType="{x:Type compareVm:ConnectionSideViewModel}">

        <GroupBox Padding="6" Margin="5">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Server type     -->
                    <RowDefinition Height="Auto"/>
                    <!-- Server name     -->
                    <RowDefinition Height="Auto"/>
                    <!-- Auth type       -->
                    <RowDefinition Height="Auto"/>
                    <!-- Port            -->
                    <RowDefinition Height="Auto"/>
                    <!-- Username        -->
                    <RowDefinition Height="Auto"/>
                    <!-- Password        -->
                    <RowDefinition Height="Auto"/>
                    <!-- Connect button  -->
                    <RowDefinition Height="Auto"/>
                    <!-- Status          -->
                    <RowDefinition Height="Auto"/>
                    <!-- Database picker -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Server type -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server type:"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>
                <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                           ItemsSource="{Binding AvailableProviders}"
                           SelectedItem="{Binding SelectedProvider}"/>

                <!-- Server name -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Server name:"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                           Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Authentication type -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Authentication:"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>
                <ComboBox  Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                           ItemsSource="{Binding AvailableAuthTypes}"
                           SelectedValue="{Binding SelectedAuthType}"
                           SelectedValuePath="Value"
                           DisplayMemberPath="Display"/>

                <!-- Port -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Port:"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
                           Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Username -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Username:"
                           VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"
                           Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                           IsEnabled="{Binding IsSqlAuthentication}"/>

                <!-- Password — bound via attached helper (no code-behind needed) -->
                <TextBlock   Grid.Row="5" Grid.Column="0" Text="Password:"
                             VerticalAlignment="Center" Margin="0,0,0,8"/>
                <PasswordBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"
                             helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding Password,
                                 Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsSqlAuthentication}"/>
                <!-- Connect button -->
                <Button Grid.Row="6" Grid.ColumnSpan="2"
                        Content="Connect"
                        Command="{Binding ConnectCommand}"
                        HorizontalAlignment="Right"
                        Width="90" Margin="0,0,0,8"/>
                <!-- Status strip -->
                <Border Grid.Row="7" Grid.ColumnSpan="2"
                        Margin="0,0,0,8" Padding="8,5" CornerRadius="4"
                        Visibility="{Binding HasStatus,
                            Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                    <Setter Property="Background" Value="#DFF0D8"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                    <Setter Property="Background" Value="#F2DEDE"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12"/>
                </Border>
                <!--
                    Database selector — virtualized so 1 000+ items stay smooth.
                    VirtualizingStackPanel + Recycling keeps memory flat; items are
                    realised on demand rather than all at once.
                -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Database:"
                           VerticalAlignment="Center" Margin="0,0,0,0"/>
                <ComboBox  Grid.Row="8" Grid.Column="1"
                           ItemsSource="{Binding Databases}"
                           SelectedItem="{Binding SelectedDatabase}"
                           IsEnabled="{Binding IsConnected}"
                           VirtualizingStackPanel.IsVirtualizing="True"
                           VirtualizingStackPanel.VirtualizationMode="Recycling"
                           ScrollViewer.CanContentScroll="True">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>
            </Grid>
        </GroupBox>
    </DataTemplate>
</ResourceDictionary>