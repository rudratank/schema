<Window x:Class="DbForge.WPF.Views.Compare.CompareResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DbForge.WPF.ViewModels.Compare"
        Title="Schema Compare — Results"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#1A1F2E">

    <Window.Resources>

        <!-- ── Palette ───────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgApp"        Color="#1A1F2E"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#242937"/>
        <SolidColorBrush x:Key="BgHeader"     Color="#141824"/>
        <SolidColorBrush x:Key="BgRow"        Color="#1E2332"/>
        <SolidColorBrush x:Key="BgRowAlt"     Color="#1A1F2E"/>
        <SolidColorBrush x:Key="BgRowHover"   Color="#2A3045"/>
        <SolidColorBrush x:Key="BgRowSel"     Color="#1C3A6B"/>
        <SolidColorBrush x:Key="BgColHeader"  Color="#141824"/>
        <SolidColorBrush x:Key="BgCodePane"   Color="#0D1117"/>

        <!-- Group colours -->
        <SolidColorBrush x:Key="BgGroupSrc"   Color="#2A1F0A"/>
        <SolidColorBrush x:Key="AccentSrc"    Color="#F59E0B"/>
        <SolidColorBrush x:Key="BgGroupDiff"  Color="#0A1A2E"/>
        <SolidColorBrush x:Key="AccentDiff"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="BgGroupTgt"   Color="#2A0A0A"/>
        <SolidColorBrush x:Key="AccentTgt"    Color="#EF4444"/>
        <SolidColorBrush x:Key="BgGroupEq"    Color="#181E2C"/>
        <SolidColorBrush x:Key="AccentEq"     Color="#6B7280"/>

        <!-- Text -->
        <SolidColorBrush x:Key="FgPrimary"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="FgMuted"      Color="#64748B"/>
        <SolidColorBrush x:Key="FgCode"       Color="#E2E8F0"/>

        <!-- Borders -->
        <SolidColorBrush x:Key="Border"       Color="#2D3748"/>
        <SolidColorBrush x:Key="BorderLight"  Color="#374151"/>

        <!-- Ops -->
        <SolidColorBrush x:Key="OpCreate"     Color="#22C55E"/>
        <SolidColorBrush x:Key="OpUpdate"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="OpDrop"       Color="#EF4444"/>
        <SolidColorBrush x:Key="OpEqual"      Color="#4B5563"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Invisible toggle button (filter chips) ─────────────────────── -->
        <Style x:Key="FilterChip" TargetType="ToggleButton">
            <Setter Property="Padding"          Value="10,4"/>
            <Setter Property="Margin"           Value="0,0,6,0"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="PART_Border" Property="Opacity" Value="0.35"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Code pane button ──────────────────────────────────────────── -->
        <Style x:Key="CodeBtn" TargetType="Button">
            <Setter Property="Background"    Value="#1E2A3A"/>
            <Setter Property="Foreground"    Value="#94A3B8"/>
            <Setter Property="BorderBrush"   Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="8,3"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D3A4D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── GridView column header ─────────────────────────────────────── -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="{StaticResource BgColHeader}"/>
            <Setter Property="Foreground"   Value="{StaticResource FgMuted}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="BorderBrush"  Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListView row ───────────────────────────────────────────────── -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background"          Value="Transparent"/>
            <Setter Property="Foreground"          Value="{StaticResource FgPrimary}"/>
            <Setter Property="Padding"             Value="0"/>
            <Setter Property="Margin"              Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="PART_Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{StaticResource Border}">
                            <GridViewRowPresenter Columns="{Binding Path=View.Columns,
                                RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Bd" Property="Background"
                                        Value="{StaticResource BgRowHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PART_Bd" Property="Background"
                                        Value="{StaticResource BgRowSel}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- HEADER BAR                                                       -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgHeader}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Source → Target -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Source badge -->
                    <Border Background="#1A2234" CornerRadius="4"
                            BorderBrush="#2D3748" BorderThickness="1"
                            Padding="10,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <!-- DB cylinder icon placeholder -->
                            <Border Width="14" Height="14" Margin="0,0,6,0"
                                    CornerRadius="3" Background="#22C55E"
                                    VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="{Binding SourceLabel}"
                                           Foreground="{StaticResource FgPrimary}"
                                           FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Arrow -->
                    <TextBlock Text="⟶" Foreground="#3B82F6" FontSize="20"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <!-- Target badge -->
                    <Border Background="#1A2234" CornerRadius="4"
                            BorderBrush="#2D3748" BorderThickness="1"
                            Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="14" Height="14" Margin="0,0,6,0"
                                    CornerRadius="3" Background="#EF4444"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TargetLabel}"
                                       Foreground="{StaticResource FgPrimary}"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right: total selected -->
                <TextBlock Grid.Column="1"
                           Text="{Binding TotalSelected}"
                           Foreground="{StaticResource FgMuted}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                       -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource BgHeader}"
                   Foreground="#64748B"
                   BorderBrush="{StaticResource Border}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TotalSelected}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- TOOLBAR: filter chips + search                                   -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="12,5">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Show:" Foreground="{StaticResource FgMuted}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <ToggleButton Style="{StaticResource FilterChip}"
                              IsChecked="{Binding ShowOnlyInSource}"
                              Background="#2A1F0A" Foreground="#F59E0B"
                              BorderBrush="#F59E0B">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#F59E0B" Margin="0,0,5,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Only in Source" Foreground="#F59E0B"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Style="{StaticResource FilterChip}"
                              IsChecked="{Binding ShowDifferent}"
                              Background="#0A1A2E" Foreground="#3B82F6"
                              BorderBrush="#3B82F6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#3B82F6" Margin="0,0,5,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Different" Foreground="#3B82F6"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Style="{StaticResource FilterChip}"
                              IsChecked="{Binding ShowOnlyInTarget}"
                              Background="#2A0A0A" Foreground="#EF4444"
                              BorderBrush="#EF4444">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#EF4444" Margin="0,0,5,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Only in Target" Foreground="#EF4444"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Style="{StaticResource FilterChip}"
                              IsChecked="{Binding ShowIdentical}"
                              Background="#181E2C" Foreground="#6B7280"
                              BorderBrush="#4B5563">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#6B7280" Margin="0,0,5,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Identical" Foreground="#6B7280"/>
                    </StackPanel>
                </ToggleButton>

                <Separator Background="{StaticResource Border}" Margin="10,2"/>

                <!-- Search -->
                <Border BorderBrush="{StaticResource Border}" BorderThickness="1"
                        CornerRadius="4" Background="#141824" Padding="7,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="10" Foreground="#4B5563"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="170" BorderThickness="0"
                                 Background="Transparent" Foreground="{StaticResource FgPrimary}"
                                 FontSize="12" VerticalAlignment="Center"
                                 CaretBrush="#E2E8F0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- MAIN AREA: Grid results (top) + SQL split panes (bottom)         -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="6"/>
                <RowDefinition x:Name="SqlPaneRow" Height="270" MinHeight="120" MaxHeight="500"/>
            </Grid.RowDefinitions>

            <!-- ── TOP: compare grid ──────────────────────────────────────── -->
            <ListView x:Name="CompareList"
                      Grid.Row="0"
                      ItemsSource="{Binding ItemsView}"
                      SelectedItem="{Binding SelectedRow}"
                      Background="{StaticResource BgRow}"
                      Foreground="{StaticResource FgPrimary}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">

                <ListView.View>
                    <GridView>

                        <!-- Type -->
                        <GridViewColumn Header="Type" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                    <StackPanel Orientation="Horizontal" Margin="6,0">
                                        <TextBlock Text="{Binding TypeIcon}"
                                                   FontSize="12" Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource FgMuted}"/>
                                        <TextBlock Text="{Binding ObjectType}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource FgPrimary}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Owner (source) -->
                        <GridViewColumn Header="Owner" Width="65">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                    <TextBlock Text="{Binding Owner}"
                                               FontSize="11" Margin="6,0"
                                               Foreground="{StaticResource FgMuted}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Source Object -->
                        <GridViewColumn Header="Source Object" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                    <TextBlock Text="{Binding SourceObjectName}"
                                               FontSize="12" Margin="6,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FgPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Checkbox -->
                        <GridViewColumn Header="✓" Width="32">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                    <CheckBox IsChecked="{Binding IsChecked}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Operation -->
                        <GridViewColumn Header="Operation" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                    <StackPanel Orientation="Horizontal" Margin="6,0"
                                                VerticalAlignment="Center">
                                        <!-- Coloured arrow symbol -->
                                        <TextBlock Text="{Binding OperationSymbol}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Create">
                                                            <Setter Property="Foreground" Value="{StaticResource OpCreate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Update">
                                                            <Setter Property="Foreground" Value="{StaticResource OpUpdate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Drop">
                                                            <Setter Property="Foreground" Value="{StaticResource OpDrop}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Equal">
                                                            <Setter Property="Foreground" Value="{StaticResource OpEqual}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Operation}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Create">
                                                            <Setter Property="Foreground" Value="{StaticResource OpCreate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Update">
                                                            <Setter Property="Foreground" Value="{StaticResource OpUpdate}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Drop">
                                                            <Setter Property="Foreground" Value="{StaticResource OpDrop}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Operation}" Value="Equal">
                                                            <Setter Property="Foreground" Value="{StaticResource OpEqual}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Target Object -->
                        <GridViewColumn Header="Target Object" Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                    <TextBlock Text="{Binding TargetObjectName}"
                                               FontSize="12" Margin="6,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FgPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Target Owner -->
                        <GridViewColumn Header="Owner" Width="65">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                    <TextBlock Text="{Binding TargetOwner}"
                                               FontSize="11" Margin="6,0"
                                               Foreground="{StaticResource FgMuted}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

                <!-- ── Group headers ───────────────────────────────────── -->
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <Expander x:Name="PART_Exp" IsExpanded="True">

                                                <!-- Expander header button: invisible, custom -->
                                                <Expander.Style>
                                                    <Style TargetType="Expander">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Expander">
                                                                    <StackPanel>
                                                                        <!-- Group header row -->
                                                                        <Border x:Name="GroupHeader"
                                                                                Padding="8,5"
                                                                                BorderThickness="0,0,0,1"
                                                                                BorderBrush="{StaticResource Border}"
                                                                                Cursor="Hand">
                                                                            <Border.InputBindings>
                                                                                <MouseBinding MouseAction="LeftClick"
                                                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Expander},
                                                                                              Path=Tag}"/>
                                                                            </Border.InputBindings>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <!-- Expand toggle -->
                                                                                <TextBlock x:Name="Arrow"
                                                                                           Text="▸"
                                                                                           FontSize="10"
                                                                                           Foreground="#4B5563"
                                                                                           VerticalAlignment="Center"
                                                                                           Margin="2,0,8,0"/>

                                                                                <!-- Coloured dot -->
                                                                                <Ellipse Grid.Column="1"
                                                                                         x:Name="Dot"
                                                                                         Width="9" Height="9"
                                                                                         VerticalAlignment="Center"
                                                                                         Margin="0,0,8,0"/>

                                                                                <!-- Group name + count -->
                                                                                <TextBlock Grid.Column="2"
                                                                                           x:Name="Label"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           VerticalAlignment="Center">
                                                                                    <Run Text="{Binding Name,Mode=OneWay}"/>
                                                                                    <Run Text=" ("/>
                                                                                    <Run Text="{Binding ItemCount,Mode=OneWay}"/>
                                                                                    <Run Text=" objects)"/>
                                                                                </TextBlock>

                                                                            </Grid>
                                                                        </Border>
                                                                        <!-- Children -->
                                                                        <ContentPresenter x:Name="Content"
                                                                                          Visibility="Visible"/>
                                                                    </StackPanel>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsExpanded" Value="False">
                                                                            <Setter TargetName="Content" Property="Visibility" Value="Collapsed"/>
                                                                            <Setter TargetName="Arrow"   Property="Text"       Value="▸"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsExpanded" Value="True">
                                                                            <Setter TargetName="Arrow"   Property="Text"       Value="▾"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Expander.Style>

                                                <ItemsPresenter/>
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>

                        <!-- Simpler approach: DataTemplate for the group header -->
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border x:Name="GroupHeaderBd"
                                        Padding="10,6"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource Border}">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Coloured dot — styled in code-behind via Tag trick;
                                             here we use a simple approach with name-based lookup -->
                                        <Ellipse x:Name="StatusDot"
                                                 Width="9" Height="9"
                                                 Fill="#F59E0B"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"/>
                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding Name,Mode=OneWay}"/>
                                            <Run Text=" (" Foreground="#4B5563"/>
                                            <Run Text="{Binding ItemCount,Mode=OneWay}" Foreground="#4B5563"/>
                                            <Run Text=" of " Foreground="#4B5563"/>
                                            <Run Text="{Binding ItemCount,Mode=OneWay}" Foreground="#4B5563"/>
                                            <Run Text=" objects selected)" Foreground="#4B5563"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Background and dot colour by group name -->
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Name,Mode=OneWay}" Value="Only in Source">
                                                    <Setter Property="Background" Value="{StaticResource BgGroupSrc}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Name,Mode=OneWay}" Value="Different">
                                                    <Setter Property="Background" Value="{StaticResource BgGroupDiff}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Name,Mode=OneWay}" Value="Only in Target">
                                                    <Setter Property="Background" Value="{StaticResource BgGroupTgt}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Name}" Value="Identical">
                                                    <Setter Property="Background" Value="{StaticResource BgGroupEq}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Dot colour triggers on the Ellipse -->
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Name,Mode=OneWay}" Value="Only in Source">
                                        <Setter TargetName="StatusDot" Property="Fill" Value="{StaticResource AccentSrc}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Name,Mode=OneWay}" Value="Different">
                                        <Setter TargetName="StatusDot" Property="Fill" Value="{StaticResource AccentDiff}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Name,Mode=OneWay}" Value="Only in Target">
                                        <Setter TargetName="StatusDot" Property="Fill" Value="{StaticResource AccentTgt}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Name,Mode=OneWay}" Value="Identical">
                                        <Setter TargetName="StatusDot" Property="Fill" Value="{StaticResource AccentEq}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>

            </ListView>

            <!-- ── Horizontal GridSplitter ────────────────────────────────── -->
            <GridSplitter Grid.Row="1"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#0D1117"
                          Cursor="SizeNS">
                <!-- Grab handle visual -->
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="#0D1117">
                            <Rectangle Height="2" Width="40"
                                       Fill="#2D3748" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" RadiusX="1" RadiusY="1"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- ── BOTTOM: dual SQL panes ─────────────────────────────────── -->
            <Grid Grid.Row="2" Background="{StaticResource BgCodePane}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT: Source SQL ─────────────────────────────────── -->
                <DockPanel Grid.Column="0">

                    <!-- Source pane header -->
                    <Border DockPanel.Dock="Top"
                            Background="#141824"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="10" Height="10" CornerRadius="2"
                                        Background="#22C55E" Margin="0,0,7,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SourcePaneHeader}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource FgPrimary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource CodeBtn}"
                                    Content="⎘  Copy"
                                    Command="{Binding CopySourceCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Source SQL TextBox -->
                    <TextBox DockPanel.Dock="Bottom"
                             Text="{Binding SourceSql, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="{StaticResource BgCodePane}"
                             Foreground="{StaticResource FgCode}"
                             CaretBrush="#E2E8F0"
                             BorderThickness="0"
                             Padding="14,10"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>

                <!-- ── Vertical splitter between panes ──────────────────── -->
                <GridSplitter Grid.Column="1" Width="5"
                              HorizontalAlignment="Stretch"
                              Background="#0D1117"/>

                <!-- ── RIGHT: Target SQL ─────────────────────────────────── -->
                <DockPanel Grid.Column="2">

                    <!-- Target pane header -->
                    <Border DockPanel.Dock="Top"
                            Background="#141824"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1,0,0,1"
                            Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="10" Height="10" CornerRadius="2"
                                        Background="#EF4444" Margin="0,0,7,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TargetPaneHeader}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource FgPrimary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource CodeBtn}"
                                    Content="⎘  Copy"
                                    Command="{Binding CopyTargetCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Target SQL TextBox -->
                    <TextBox DockPanel.Dock="Bottom"
                             Text="{Binding TargetSql, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="{StaticResource BgCodePane}"
                             Foreground="{StaticResource FgCode}"
                             CaretBrush="#E2E8F0"
                             BorderThickness="1,0,0,0"
                             BorderBrush="{StaticResource Border}"
                             Padding="14,10"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
