<Window x:Class="DbForge.WPF.Views.Compare.CompareResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DbForge.WPF.ViewModels.Compare"
        xmlns:h="clr-namespace:DbForge.WPF.UI.Helpers"
        Title="Schema Compare — Results"
        Width="1440" Height="880"
        MinWidth="960" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgApp}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Counter badge style -->
        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="7,2"/>
            <Setter Property="MinWidth"        Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Object type chip (smaller than status chip) -->
        <Style x:Key="TypeChip" TargetType="ToggleButton" BasedOn="{StaticResource FilterChip}">
            <Setter Property="Padding"  Value="8,3"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin"   Value="0,0,4,0"/>
            <Setter Property="Background"  Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="Foreground"  Value="{DynamicResource FgSecondary}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <DockPanel>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- HEADER BAR                                                     -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource BgHeader}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,0,1"
                    Padding="16,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: db labels + arrow + refresh -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Source db chip -->
                        <Border Background="{DynamicResource BgCard}"
                                CornerRadius="{DynamicResource RadiusSmall}"
                                BorderBrush="{DynamicResource ColorSuccess}"
                                BorderThickness="1" Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="9" Height="9" CornerRadius="2"
                                        Background="{DynamicResource ColorSuccess}"
                                        Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SourceLabel}"
                                           Foreground="{DynamicResource FgPrimary}"
                                           FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="⟶" Foreground="{DynamicResource AccentPrimary}"
                                   FontSize="18" VerticalAlignment="Center" Margin="10,0"/>

                        <!-- Target db chip -->
                        <Border Background="{DynamicResource BgCard}"
                                CornerRadius="{DynamicResource RadiusSmall}"
                                BorderBrush="{DynamicResource ColorError}"
                                BorderThickness="1" Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="9" Height="9" CornerRadius="2"
                                        Background="{DynamicResource ColorError}"
                                        Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TargetLabel}"
                                           Foreground="{DynamicResource FgPrimary}"
                                           FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                        <!-- Refresh button -->
                        <Button Content="⟳  Refresh"
                                Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                Margin="18,0,0,0" Padding="12,5" FontSize="12"
                                Background="{DynamicResource BtnDefaultBg}"
                                Foreground="{DynamicResource BtnDefaultFg}"
                                BorderBrush="{DynamicResource AccentPrimary}"
                                BorderThickness="1" Cursor="Hand"/>

                        <!-- Counter badges -->
                        <Border Style="{StaticResource CountBadge}"
                                Background="{DynamicResource BgSuccess}"
                                BorderBrush="{DynamicResource ColorSuccess}"
                                BorderThickness="1" Margin="18,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" Foreground="{DynamicResource ColorSuccess}"
                                           FontWeight="Bold" FontSize="11" Margin="0,0,3,0"/>
                                <TextBlock Text="{Binding AddedCount}"
                                           Foreground="{DynamicResource ColorSuccess}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CountBadge}"
                                Background="{DynamicResource BgWarning}"
                                BorderBrush="{DynamicResource ColorWarning}"
                                BorderThickness="1" Margin="5,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="~" Foreground="{DynamicResource ColorWarning}"
                                           FontWeight="Bold" FontSize="11" Margin="0,0,3,0"/>
                                <TextBlock Text="{Binding ModifiedCount}"
                                           Foreground="{DynamicResource ColorWarning}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CountBadge}"
                                Background="{DynamicResource BgError}"
                                BorderBrush="{DynamicResource ColorError}"
                                BorderThickness="1" Margin="5,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="−" Foreground="{DynamicResource ColorError}"
                                           FontWeight="Bold" FontSize="11" Margin="0,0,3,0"/>
                                <TextBlock Text="{Binding RemovedCount}"
                                           Foreground="{DynamicResource ColorError}" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right: selection count + deselect/select all -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalSelected}"
                                   Foreground="{DynamicResource FgMuted}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="✓ All"   Command="{Binding SelectAllCommand}"
                                Padding="8,4" FontSize="11" Margin="0,0,5,0"/>
                        <Button Content="✗ None"  Command="{Binding DeselectAllCommand}"
                                Padding="8,4" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- STATUS BAR                                                     -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <StatusBar DockPanel.Dock="Bottom"
                       BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}" FontSize="11"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock Text="{Binding TotalSelected}" FontSize="11"/>
                </StatusBarItem>
            </StatusBar>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- TOOLBAR  (status filters + type filters + search)             -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,0,1"
                    Padding="12,5">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">

                    <!-- Row 1: status chips + search -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Status:" Foreground="{DynamicResource FgMuted}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                   FontWeight="SemiBold"/>

                        <ToggleButton Style="{StaticResource FilterChip}"
                                      IsChecked="{Binding ShowOnlyInSource}"
                                      Background="{DynamicResource BgGroupSrc}"
                                      BorderBrush="{DynamicResource AccentSrc}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentSrc}"
                                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Only in Source" Foreground="{DynamicResource AccentSrc}"/>
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource FilterChip}"
                                      IsChecked="{Binding ShowDifferent}"
                                      Background="{DynamicResource BgGroupDiff}"
                                      BorderBrush="{DynamicResource AccentDiff}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentDiff}"
                                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Different" Foreground="{DynamicResource AccentDiff}"/>
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource FilterChip}"
                                      IsChecked="{Binding ShowOnlyInTarget}"
                                      Background="{DynamicResource BgGroupTgt}"
                                      BorderBrush="{DynamicResource AccentTgt}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentTgt}"
                                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Only in Target" Foreground="{DynamicResource AccentTgt}"/>
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource FilterChip}"
                                      IsChecked="{Binding ShowIdentical}"
                                      Background="{DynamicResource BgGroupEq}"
                                      BorderBrush="{DynamicResource AccentEq}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentEq}"
                                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Identical" Foreground="{DynamicResource AccentEq}"/>
                            </StackPanel>
                        </ToggleButton>

                        <Separator Margin="6,0"/>

                        <!-- Search box -->
                        <Border BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                CornerRadius="{DynamicResource RadiusSmall}"
                                Background="{DynamicResource BgHeader}" Padding="7,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="10"
                                           Foreground="{DynamicResource FgMuted}"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Width="170" BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource FgPrimary}"
                                         FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Row 2: object-type chips -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Types:  " Foreground="{DynamicResource FgMuted}"
                                   FontSize="10" VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <ToggleButton Style="{StaticResource TypeChip}"
                                      IsChecked="{Binding ShowTables}">
                            <TextBlock Text="⊞  Tables"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource TypeChip}"
                                      IsChecked="{Binding ShowProcedures}">
                            <TextBlock Text="⚙  Procedures"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource TypeChip}"
                                      IsChecked="{Binding ShowViews}">
                            <TextBlock Text="◫  Views"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource TypeChip}"
                                      IsChecked="{Binding ShowFunctions}">
                            <TextBlock Text="ƒ  Functions"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource TypeChip}"
                                      IsChecked="{Binding ShowTriggers}">
                            <TextBlock Text="⚡  Triggers"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource TypeChip}"
                                      IsChecked="{Binding ShowSynonyms}">
                            <TextBlock Text="↔  Synonyms"/>
                        </ToggleButton>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- MAIN AREA                                                      -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition x:Name="SqlPaneRow" Height="320" MinHeight="150" MaxHeight="580"/>
                </Grid.RowDefinitions>

                <!-- ── Compare grid ──────────────────────────────────────── -->
                <ListView x:Name="CompareList"
                          Grid.Row="0"
                          ItemsSource="{Binding ItemsView}"
                          SelectedItem="{Binding SelectedRow}"
                          Background="{DynamicResource BgRow}"
                          Foreground="{DynamicResource FgPrimary}"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Type" Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <TextBlock Text="{Binding TypeIcon}" FontSize="12"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource FgMuted}"/>
                                            <TextBlock Text="{Binding ObjectType}" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Owner" Width="65">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                        <TextBlock Text="{Binding Owner}" FontSize="11" Margin="6,0"
                                                   Foreground="{DynamicResource FgMuted}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Source Object" Width="230">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                        <TextBlock Text="{Binding SourceObjectName}" FontSize="12"
                                                   Margin="6,0" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="✓" Width="32">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                        <CheckBox IsChecked="{Binding IsChecked}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" Margin="0"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Operation" Width="115">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                        <StackPanel Orientation="Horizontal" Margin="6,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding OperationSymbol}" FontSize="14"
                                                       Margin="0,0,5,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Operation}" Value="Create">
                                                                <Setter Property="Foreground" Value="{DynamicResource OpCreate}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Operation}" Value="Update">
                                                                <Setter Property="Foreground" Value="{DynamicResource OpUpdate}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Operation}" Value="Drop">
                                                                <Setter Property="Foreground" Value="{DynamicResource OpDrop}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Operation}" FontSize="12"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Operation}" Value="Create">
                                                                <Setter Property="Foreground" Value="{DynamicResource OpCreate}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Operation}" Value="Update">
                                                                <Setter Property="Foreground" Value="{DynamicResource OpUpdate}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Operation}" Value="Drop">
                                                                <Setter Property="Foreground" Value="{DynamicResource OpDrop}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Target Object" Width="230">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                        <TextBlock Text="{Binding TargetObjectName}" FontSize="12"
                                                   Margin="6,0" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Owner" Width="65">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:CompareRowViewModel}">
                                        <TextBlock Text="{Binding TargetOwner}" FontSize="11"
                                                   Margin="6,0" Foreground="{DynamicResource FgMuted}"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>

                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border x:Name="GroupHeaderBd" Padding="10,6"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource Border}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                                     Fill="{DynamicResource AccentSrc}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                <Run Text=" (" Foreground="{DynamicResource FgMuted}"/>
                                                <Run Text="{Binding ItemCount, Mode=OneWay}"
                                                     Foreground="{DynamicResource FgMuted}"/>
                                                <Run Text=" objects)" Foreground="{DynamicResource FgMuted}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Name}" Value="Only in Source">
                                                        <Setter Property="Background" Value="{DynamicResource BgGroupSrc}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="Different">
                                                        <Setter Property="Background" Value="{DynamicResource BgGroupDiff}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="Only in Target">
                                                        <Setter Property="Background" Value="{DynamicResource BgGroupTgt}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="Identical">
                                                        <Setter Property="Background" Value="{DynamicResource BgGroupEq}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Name}" Value="Only in Source">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="{DynamicResource AccentSrc}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Name}" Value="Different">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="{DynamicResource AccentDiff}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Name}" Value="Only in Target">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="{DynamicResource AccentTgt}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Name}" Value="Identical">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="{DynamicResource AccentEq}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                </ListView>

                <!-- ── GridSplitter ──────────────────────────────────────── -->
                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" Cursor="SizeNS">
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Border Background="{DynamicResource BgHeader}">
                                <Rectangle Height="2" Width="50"
                                           Fill="{DynamicResource Border}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           RadiusX="1" RadiusY="1"/>
                            </Border>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <!-- ══════════════════════════════════════════════════════════
                     DIFF PANEL  — DbForge-style bordered frame
                     ══════════════════════════════════════════════════════════ -->
                <Border Grid.Row="2"
                        Margin="6,4,6,6"
                        Background="{DynamicResource BgCodePane}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}">

                    <!-- Blue top-accent bar (DbForge hallmark) -->
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                          Direction="270" Opacity="0.4"
                                          Color="#000000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Coloured top accent line -->
                            <RowDefinition Height="3"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Accent bar: gradient from source-green to target-red via blue -->
                        <Border Grid.Row="0" CornerRadius="6,6,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#22C55E" Offset="0.0"/>
                                    <GradientStop Color="#388BFD" Offset="0.5"/>
                                    <GradientStop Color="#EF4444" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Inner panel content -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="195" MinWidth="120" MaxWidth="340"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── Object Tree ──────────────────────────── -->
                            <DockPanel Grid.Column="0">
                                <Border DockPanel.Dock="Top"
                                        Background="{DynamicResource BgHeader}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="0,0,1,1" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="◈" FontSize="10"
                                                   Foreground="{DynamicResource AccentPrimary}"
                                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Objects" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource FgMuted}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto"
                                              Background="{DynamicResource BgCodePane}">
                                    <TreeView ItemsSource="{Binding DiffTree}"
                                              Background="Transparent" BorderThickness="0"
                                              Foreground="{DynamicResource FgPrimary}"
                                              ItemContainerStyle="{StaticResource DiffTreeItemStyle}">
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                                                      DataType="{x:Type vm:DiffTreeNode}">
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <Ellipse Width="6" Height="6"
                                                             VerticalAlignment="Center" Margin="0,0,5,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource TreeIdentical}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Added">
                                                                        <Setter Property="Fill" Value="{DynamicResource TreeAdded}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Removed">
                                                                        <Setter Property="Fill" Value="{DynamicResource TreeRemoved}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Modified">
                                                                        <Setter Property="Fill" Value="{DynamicResource TreeModified}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Icon}" FontSize="10"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource FgMuted}"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="11"
                                                               FontFamily="Consolas" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Added">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TreeAdded}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Removed">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TreeRemoved}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Modified">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TreeModified}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </ScrollViewer>
                            </DockPanel>

                            <GridSplitter Grid.Column="1" Width="5"
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource BgCodePane}"/>

                            <!-- ── SOURCE pane ────────────────────────────── -->
                            <DockPanel Grid.Column="2">
                                <Border DockPanel.Dock="Top"
                                        Background="{DynamicResource BgHeader}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="0,0,0,1" Padding="12,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Green source indicator -->
                                            <Border Width="3" Height="16" CornerRadius="1.5"
                                                    Background="{DynamicResource ColorSuccess}"
                                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SourcePaneHeader}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="{DynamicResource FgPrimary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource CodeBtn}"
                                                Content="⎘  Copy" Command="{Binding CopySourceCommand}"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer x:Name="SourceScroller"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DiffPairs}"
                                                  Background="{DynamicResource BgCodePane}"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SqlDiffPair}">
                                                <Border x:Name="CellBd" Margin="0,0,0,1"
                                                        Background="{DynamicResource BgCodePane}"
                                                        BorderThickness="0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border x:Name="GutterBd"
                                                                Background="{DynamicResource BgHeader}"
                                                                BorderBrush="{DynamicResource BorderLight}"
                                                                BorderThickness="0,0,1,0">
                                                            <TextBlock x:Name="GutterTxt" Text=""
                                                                       FontFamily="Consolas" FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource FgMuted}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1"
                                                                   x:Name="CodeTxt"
                                                                   h:TextBlockHelper.HighlightKind="Source"
                                                                   h:TextBlockHelper.Segments="{Binding Source.Segments}"
                                                                   FontFamily="Consolas" FontSize="12"
                                                                   Padding="8,2" VerticalAlignment="Center"
                                                                   TextWrapping="NoWrap"
                                                                   Foreground="{DynamicResource FgCode}"/>
                                                    </Grid>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Source.LineKind}" Value="Added">
                                                                    <Setter Property="Background" Value="{DynamicResource DiffAdded}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Source.LineKind}" Value="Removed">
                                                                    <Setter Property="Background"  Value="{DynamicResource DiffRemoved}"/>
                                                                    <Setter Property="BorderBrush"     Value="{DynamicResource FgRemoved}"/>
                                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Source.LineKind}" Value="Modified">
                                                                    <Setter Property="Background"  Value="{DynamicResource DiffModified}"/>
                                                                    <Setter Property="BorderBrush"     Value="{DynamicResource FgModified}"/>
                                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Source.LineKind}" Value="Empty">
                                                                    <Setter Property="Background" Value="{DynamicResource DiffEmpty}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Source.LineKind}" Value="SectionHeader">
                                                                    <Setter Property="Background" Value="{DynamicResource DiffSection}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Source.LineKind}" Value="Removed">
                                                        <Setter TargetName="GutterTxt" Property="Text"      Value="−"/>
                                                        <Setter TargetName="GutterTxt" Property="Foreground" Value="{DynamicResource FgRemoved}"/>
                                                        <Setter TargetName="GutterBd"  Property="Background" Value="{DynamicResource BgError}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Source.LineKind}" Value="Added">
                                                        <Setter TargetName="GutterTxt" Property="Text"      Value="+"/>
                                                        <Setter TargetName="GutterTxt" Property="Foreground" Value="{DynamicResource FgAdded}"/>
                                                        <Setter TargetName="GutterBd"  Property="Background" Value="{DynamicResource BgSuccess}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Source.LineKind}" Value="Modified">
                                                        <Setter TargetName="GutterTxt" Property="Text"      Value="~"/>
                                                        <Setter TargetName="GutterTxt" Property="Foreground" Value="{DynamicResource FgModified}"/>
                                                        <Setter TargetName="GutterBd"  Property="Background" Value="{DynamicResource BgWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Source.LineKind}" Value="SectionHeader">
                                                        <Setter TargetName="CodeTxt" Property="Foreground" Value="{DynamicResource FgSection}"/>
                                                        <Setter TargetName="CodeTxt" Property="FontStyle"  Value="Italic"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>

                            <GridSplitter Grid.Column="3" Width="5"
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource BgCodePane}"/>

                            <!-- ── TARGET pane ────────────────────────────── -->
                            <DockPanel Grid.Column="4">
                                <Border DockPanel.Dock="Top"
                                        Background="{DynamicResource BgHeader}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1,0,0,1" Padding="12,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Red target indicator -->
                                            <Border Width="3" Height="16" CornerRadius="1.5"
                                                    Background="{DynamicResource ColorError}"
                                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TargetPaneHeader}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="{DynamicResource FgPrimary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource CodeBtn}"
                                                Content="⎘  Copy" Command="{Binding CopyTargetCommand}"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer x:Name="TargetScroller"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DiffPairs}"
                                                  Background="{DynamicResource BgCodePane}"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SqlDiffPair}">
                                                <Border x:Name="CellBd" Margin="0,0,0,1"
                                                        Background="{DynamicResource BgCodePane}"
                                                        BorderThickness="0" MinHeight="20">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border x:Name="GutterBd"
                                                                Background="{DynamicResource BgHeader}"
                                                                BorderBrush="{DynamicResource BorderLight}"
                                                                BorderThickness="0,0,1,0">
                                                            <TextBlock x:Name="GutterTxt" Text=""
                                                                       FontFamily="Consolas" FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource FgMuted}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1"
                                                                   x:Name="CodeTxt"
                                                                   h:TextBlockHelper.HighlightKind="Target"
                                                                   h:TextBlockHelper.Segments="{Binding Target.Segments}"
                                                                   FontFamily="Consolas" FontSize="12"
                                                                   Padding="8,2" VerticalAlignment="Center"
                                                                   TextWrapping="NoWrap"
                                                                   Foreground="{DynamicResource FgCode}"/>
                                                    </Grid>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Target.LineKind}" Value="Added">
                                                                    <Setter Property="Background"  Value="{DynamicResource DiffAdded}"/>
                                                                    <Setter Property="BorderBrush"     Value="{DynamicResource FgAdded}"/>
                                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Target.LineKind}" Value="Removed">
                                                                    <Setter Property="Background" Value="{DynamicResource DiffRemoved}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Target.LineKind}" Value="Modified">
                                                                    <Setter Property="Background"  Value="{DynamicResource DiffModified}"/>
                                                                    <Setter Property="BorderBrush"     Value="{DynamicResource FgModified}"/>
                                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Target.LineKind}" Value="Empty">
                                                                    <Setter Property="Background" Value="{DynamicResource DiffEmpty}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Target.LineKind}" Value="SectionHeader">
                                                                    <Setter Property="Background" Value="{DynamicResource DiffSection}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Target.LineKind}" Value="Added">
                                                        <Setter TargetName="GutterTxt" Property="Text"      Value="+"/>
                                                        <Setter TargetName="GutterTxt" Property="Foreground" Value="{DynamicResource FgAdded}"/>
                                                        <Setter TargetName="GutterBd"  Property="Background" Value="{DynamicResource BgSuccess}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Target.LineKind}" Value="Removed">
                                                        <Setter TargetName="GutterTxt" Property="Text"      Value="−"/>
                                                        <Setter TargetName="GutterTxt" Property="Foreground" Value="{DynamicResource FgRemoved}"/>
                                                        <Setter TargetName="GutterBd"  Property="Background" Value="{DynamicResource BgError}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Target.LineKind}" Value="Modified">
                                                        <Setter TargetName="GutterTxt" Property="Text"      Value="~"/>
                                                        <Setter TargetName="GutterTxt" Property="Foreground" Value="{DynamicResource FgModified}"/>
                                                        <Setter TargetName="GutterBd"  Property="Background" Value="{DynamicResource BgWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Target.LineKind}" Value="SectionHeader">
                                                        <Setter TargetName="CodeTxt" Property="Foreground" Value="{DynamicResource FgSection}"/>
                                                        <Setter TargetName="CodeTxt" Property="FontStyle"  Value="Italic"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>

                        </Grid>
                    </Grid>
                </Border>
                <!-- end diff panel border -->

            </Grid>
        </DockPanel>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- BUSY OVERLAY  (shown during refresh)                              -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Border Background="#AA000000"/>
            <Border Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource AccentPrimary}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource RadiusMedium}"
                    Padding="32,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⟳  Refreshing comparison…"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" Margin="0,8,0,0"
                               Foreground="{DynamicResource FgSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>