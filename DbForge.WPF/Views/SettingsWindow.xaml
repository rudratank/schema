<Window x:Class="DbForge.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="680" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BgApp}">

    <DockPanel Background="{DynamicResource BgApp}">

        <!-- ── Header ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgHeader}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙" FontSize="18" Margin="0,0,10,0"
                           Foreground="{DynamicResource AccentPrimary}"
                           VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource FgPrimary}"/>
                    <TextBlock Text="Customize your DbForge experience"
                               FontSize="11" Foreground="{DynamicResource FgMuted}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Footer ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgHeader}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Apply"
                        Command="{Binding ApplyThemeCommand}"
                        Background="{DynamicResource BtnPrimaryBg}"
                        Foreground="{DynamicResource BtnPrimaryFg}"
                        BorderBrush="{DynamicResource BtnPrimaryBorder}"
                        Width="90" Margin="0,0,8,0"/>
                <Button Content="Close"
                        IsCancel="True"
                        Width="80"/>
            </StackPanel>
        </Border>

        <!-- ── Body ─────────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource BgApp}">

            <StackPanel Margin="20,16,20,16">

                <!-- ── Appearance ─────────────────────────────── -->
                <Border Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="16,14"
                        Margin="0,0,0,16">

                    <StackPanel>

                        <!-- Title -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="3"
                                    Background="{DynamicResource AccentPrimary}"
                                    Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Appearance"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Choose a color theme"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 🔥 THEME COMBOBOX -->
                        <StackPanel Margin="0,0,0,10">

                            <TextBlock Text="Theme"
                                       FontSize="11"
                                       Foreground="{DynamicResource FgMuted}"
                                       Margin="0,0,0,4"/>

                            <ComboBox
                                ItemsSource="{Binding AvailableThemes}"
                                SelectedItem="{Binding SelectedThemeItem, Mode=TwoWay}"
                                Height="32">

                                <!-- Selected display -->
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="10" Height="10"
                                                    Background="{Binding PreviewBrush}"
                                                    Margin="0,0,6,0"
                                                    CornerRadius="2"/>
                                            <TextBlock Text="{Binding Name}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>

                            </ComboBox>
                        </StackPanel>

                        <!-- Active Theme Info -->
                        <Border Background="{DynamicResource BgRowHover}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource RadiusSmall}"
                                Padding="12,8">

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Active theme: "
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"/>

                                <TextBlock Text="{Binding SelectedThemeItem.Name}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentPrimary}"/>

                                <TextBlock Text=" — "
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"/>

                                <TextBlock Text="{Binding SelectedTheme.Description}"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgSecondary}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ── Editor Settings ───────────────────────── -->
                <Border Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="16,14"
                        Margin="0,0,0,16">

                    <StackPanel>

                        <TextBlock Text="Editor"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Font Size"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"/>
                                <ComboBox SelectedItem="{Binding EditorFontSize}">
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="13"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="16"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Font Family"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgMuted}"/>
                                <ComboBox SelectedItem="{Binding EditorFontFamily}">
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="Cascadia Code"/>
                                    <ComboBoxItem Content="Fira Code"/>
                                    <ComboBoxItem Content="JetBrains Mono"/>
                                </ComboBox>
                            </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ── About ───────────────────────── -->
                <Border Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="16,14">

                    <StackPanel>
                        <TextBlock Text="About"
                                   FontSize="14"
                                   FontWeight="Bold"/>

                        <TextBlock Text="DbForge Schema Compare Tool"
                                   Margin="0,6,0,0"/>

                        <TextBlock Text="v1.0.0"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgMuted}"/>
                    </StackPanel>

                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>