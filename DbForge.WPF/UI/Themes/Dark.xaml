<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════════════════
         DARK THEME  —  DbForge Professional
         GitHub-style dark. Warm neutral grays, blue accents.
    ═══════════════════════════════════════════════════════════════ -->

    <!-- ── App background layers ─────────────────────────────────── -->
    <SolidColorBrush x:Key="BgApp"         Color="#0D1117"/>
    <SolidColorBrush x:Key="BgPanel"       Color="#161B22"/>
    <SolidColorBrush x:Key="BgHeader"      Color="#0D1117"/>
    <SolidColorBrush x:Key="BgRow"         Color="#0D1117"/>
    <SolidColorBrush x:Key="BgRowAlt"      Color="#161B22"/>
    <SolidColorBrush x:Key="BgRowHover"    Color="#1F2937"/>
    <SolidColorBrush x:Key="BgRowSel"      Color="#1C3A6B"/>
    <SolidColorBrush x:Key="BgColHeader"   Color="#0D1117"/>
    <SolidColorBrush x:Key="BgCodePane"    Color="#010409"/>
    <SolidColorBrush x:Key="BgInput"       Color="#0D1117"/>
    <SolidColorBrush x:Key="BgCard"        Color="#161B22"/>
    <SolidColorBrush x:Key="BgTooltip"     Color="#1F2937"/>
    <SolidColorBrush x:Key="BgSidebar"     Color="#0D1117"/>
    <SolidColorBrush x:Key="BgDialog"      Color="#161B22"/>

    <!-- ── Text ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="FgPrimary"     Color="#E6EDF3"/>
    <SolidColorBrush x:Key="FgSecondary"   Color="#8B949E"/>
    <SolidColorBrush x:Key="FgMuted"       Color="#484F58"/>
    <SolidColorBrush x:Key="FgCode"        Color="#E6EDF3"/>
    <SolidColorBrush x:Key="FgLink"        Color="#58A6FF"/>
    <SolidColorBrush x:Key="FgInverse"     Color="#0D1117"/>

    <!-- ── Borders ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Border"        Color="#30363D"/>
    <SolidColorBrush x:Key="BorderLight"   Color="#21262D"/>
    <SolidColorBrush x:Key="BorderFocus"   Color="#388BFD"/>
    <SolidColorBrush x:Key="BorderInput"   Color="#30363D"/>

    <!-- ── Accent / Brand ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AccentPrimary"   Color="#388BFD"/>
    <SolidColorBrush x:Key="AccentSecondary" Color="#1F6FEB"/>
    <SolidColorBrush x:Key="AccentHover"     Color="#4D9EFF"/>

    <!-- ── Semantic status ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ColorSuccess"  Color="#3FB950"/>
    <SolidColorBrush x:Key="ColorWarning"  Color="#D29922"/>
    <SolidColorBrush x:Key="ColorError"    Color="#F85149"/>
    <SolidColorBrush x:Key="ColorInfo"     Color="#58A6FF"/>
    <SolidColorBrush x:Key="BgSuccess"     Color="#0D2818"/>
    <SolidColorBrush x:Key="BgWarning"     Color="#2D1E00"/>
    <SolidColorBrush x:Key="BgError"       Color="#2D1212"/>
    <SolidColorBrush x:Key="BgInfo"        Color="#0C1F3D"/>

    <!-- ── Button ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BtnPrimaryBg"   Color="#238636"/>
    <SolidColorBrush x:Key="BtnPrimaryFg"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BtnPrimaryBorder" Color="#2EA043"/>
    <SolidColorBrush x:Key="BtnDefaultBg"   Color="#21262D"/>
    <SolidColorBrush x:Key="BtnDefaultFg"   Color="#C9D1D9"/>
    <SolidColorBrush x:Key="BtnDefaultBorder" Color="#30363D"/>
    <SolidColorBrush x:Key="BtnDangerBg"    Color="#DA3633"/>
    <SolidColorBrush x:Key="BtnDangerFg"    Color="#FFFFFF"/>

    <!-- ── Diff / Code view ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="DiffAdded"     Color="#0D2818"/>
    <SolidColorBrush x:Key="DiffRemoved"   Color="#2D1212"/>
    <SolidColorBrush x:Key="DiffModified"  Color="#141000"/>
    <SolidColorBrush x:Key="DiffEmpty"     Color="#0A0D14"/>
    <SolidColorBrush x:Key="DiffSection"   Color="#161B27"/>
    <SolidColorBrush x:Key="FgAdded"       Color="#3FB950"/>
    <SolidColorBrush x:Key="FgRemoved"     Color="#F85149"/>
    <SolidColorBrush x:Key="FgModified"    Color="#D97706"/>
    <SolidColorBrush x:Key="FgSection"     Color="#484F58"/>
    <SolidColorBrush x:Key="GutterAdded"   Color="#238636"/>
    <SolidColorBrush x:Key="GutterRemoved" Color="#DA3633"/>
    <SolidColorBrush x:Key="GutterContext" Color="#21262D"/>

    <!-- ── Compare grid groups ───────────────────────────────────── -->
    <SolidColorBrush x:Key="BgGroupSrc"    Color="#2A1F0A"/>
    <SolidColorBrush x:Key="AccentSrc"     Color="#F59E0B"/>
    <SolidColorBrush x:Key="BgGroupDiff"   Color="#0A1A2E"/>
    <SolidColorBrush x:Key="AccentDiff"    Color="#3B82F6"/>
    <SolidColorBrush x:Key="BgGroupTgt"    Color="#2A0A0A"/>
    <SolidColorBrush x:Key="AccentTgt"     Color="#EF4444"/>
    <SolidColorBrush x:Key="BgGroupEq"     Color="#181E2C"/>
    <SolidColorBrush x:Key="AccentEq"      Color="#6B7280"/>

    <!-- ── Tree status ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TreeAdded"     Color="#22C55E"/>
    <SolidColorBrush x:Key="TreeRemoved"   Color="#EF4444"/>
    <SolidColorBrush x:Key="TreeModified"  Color="#3B82F6"/>
    <SolidColorBrush x:Key="TreeIdentical" Color="#4B5563"/>

    <!-- ── Operations ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="OpCreate"      Color="#22C55E"/>
    <SolidColorBrush x:Key="OpUpdate"      Color="#3B82F6"/>
    <SolidColorBrush x:Key="OpDrop"        Color="#EF4444"/>
    <SolidColorBrush x:Key="OpEqual"       Color="#4B5563"/>

    <!-- ── ScrollBar ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ScrollBarThumb"  Color="#30363D"/>
    <SolidColorBrush x:Key="ScrollBarTrack"  Color="#0D1117"/>

    <!-- ── Scalars ────────────────────────────────────────────────── -->
    <CornerRadius  x:Key="RadiusSmall"   >3</CornerRadius>
    <CornerRadius  x:Key="RadiusMedium"  >6</CornerRadius>
    <CornerRadius  x:Key="RadiusLarge"   >10</CornerRadius>
    <Thickness     x:Key="BorderThin"    >1</Thickness>
    <sys:Double x:Key="FontSizeBase">13</sys:Double>
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="FontSizeLarge">16</sys:Double>

</ResourceDictionary>
