    ═══════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="BgApp"         Color="#F5F2EE"/>
    <SolidColorBrush x:Key="BgPanel"       Color="#FAF8F5"/>
    <SolidColorBrush x:Key="BgHeader"      Color="#F0EDE8"/>
    <SolidColorBrush x:Key="BgRow"         Color="#FAF8F5"/>
    <SolidColorBrush x:Key="BgRowAlt"      Color="#F5F2EE"/>
    <SolidColorBrush x:Key="BgRowHover"    Color="#EDE9E3"/>
    <SolidColorBrush x:Key="BgRowSel"      Color="#E3DED6"/>
    <SolidColorBrush x:Key="BgColHeader"   Color="#F0EDE8"/>
    <SolidColorBrush x:Key="BgCodePane"    Color="#FDFCFA"/>
    <SolidColorBrush x:Key="BgInput"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgCard"        Color="#FAF8F5"/>
    <SolidColorBrush x:Key="BgTooltip"     Color="#2A2520"/>
    <SolidColorBrush x:Key="BgSidebar"     Color="#F0EDE8"/>
    <SolidColorBrush x:Key="BgDialog"      Color="#FAF8F5"/>

    <SolidColorBrush x:Key="FgPrimary"     Color="#1A1612"/>
    <SolidColorBrush x:Key="FgSecondary"   Color="#5A534A"/>
    <SolidColorBrush x:Key="FgMuted"       Color="#9A9088"/>
    <SolidColorBrush x:Key="FgCode"        Color="#1A1612"/>
    <SolidColorBrush x:Key="FgLink"        Color="#3A3028"/>
    <SolidColorBrush x:Key="FgInverse"     Color="#FAF8F5"/>

    <SolidColorBrush x:Key="Border"        Color="#D6D0C8"/>
