    <SolidColorBrush x:Key="TreeIdentical" Color="#9A9088"/>

    <SolidColorBrush x:Key="OpCreate"      Color="#2D6A2D"/>
    <SolidColorBrush x:Key="OpUpdate"      Color="#205080"/>
    <SolidColorBrush x:Key="OpDrop"        Color="#8A2020"/>
    <SolidColorBrush x:Key="OpEqual"       Color="#9A9088"/>

    <SolidColorBrush x:Key="ScrollBarThumb"  Color="#C8C0B5"/>
    <SolidColorBrush x:Key="ScrollBarTrack"  Color="#F5F2EE"/>

    <CornerRadius  x:Key="RadiusSmall"   >2</CornerRadius>
    <CornerRadius  x:Key="RadiusMedium"  >4</CornerRadius>
    <CornerRadius  x:Key="RadiusLarge"   >8</CornerRadius>
    <Thickness     x:Key="BorderThin"    >1</Thickness>
    <sys:Double x:Key="FontSizeBase">13</sys:Double>
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="FontSizeLarge">16</sys:Double>

</ResourceDictionary>
