    ═══════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="BgApp"         Color="#000000"/>
    <SolidColorBrush x:Key="BgPanel"       Color="#0A0A0A"/>
    <SolidColorBrush x:Key="BgHeader"      Color="#000000"/>
    <SolidColorBrush x:Key="BgRow"         Color="#000000"/>
    <SolidColorBrush x:Key="BgRowAlt"      Color="#0A0A0A"/>
    <SolidColorBrush x:Key="BgRowHover"    Color="#1A1A2E"/>
    <SolidColorBrush x:Key="BgRowSel"      Color="#001B5E"/>
    <SolidColorBrush x:Key="BgColHeader"   Color="#000000"/>
    <SolidColorBrush x:Key="BgCodePane"    Color="#000000"/>
    <SolidColorBrush x:Key="BgInput"       Color="#000000"/>
    <SolidColorBrush x:Key="BgCard"        Color="#0A0A0A"/>
    <SolidColorBrush x:Key="BgTooltip"     Color="#000000"/>
    <SolidColorBrush x:Key="BgSidebar"     Color="#000000"/>
    <SolidColorBrush x:Key="BgDialog"      Color="#0A0A0A"/>

    <SolidColorBrush x:Key="FgPrimary"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FgSecondary"   Color="#CCCCCC"/>
