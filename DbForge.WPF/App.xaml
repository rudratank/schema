<Application x:Class="DbForge.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DbForge.WPF">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                    1. Theme dictionary — loaded FIRST so all brush/color keys exist.
                       ThemeService replaces this at runtime; the entry here is the
                       startup default (Dark) in case the service has not yet run.
                       ThemeService.Initialize() is called in OnStartup and will
                       swap this out for the user's saved preference.
                -->
                <ResourceDictionary Source="pack://application:,,,/UI/Themes/Dark.xaml"/>

                <!--
                    2. Global control styles — MUST come AFTER the theme dict
                       so every DynamicResource key is already registered.
                -->
                <ResourceDictionary Source="pack://application:,,,/UI/Themes/GlobalStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- App-wide converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
